{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "task",
            "args": ["build"],
            "group": "build",
            "problemMatcher": [
                {
                    "owner": "go",
                    "fileLocation": ["relative", "${workspaceFolder}"],
                    "pattern": {
                        "regexp": "^([^:]*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                        "file": 1,
                        "line": 2,
                        "column": 3,
                        "severity": 4,
                        "message": 5
                    }
                }
            ]
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "task",
            "args": ["clean"],
            "group": "build"
        },
        {
            "label": "Run",
            "type": "shell",
            "command": "task",
            "args": ["run"],
            "group": "build"
        },
        {
            "label": "Build Windows",
            "type": "shell",
            "command": "task",
            "args": ["cross-build-windows"],
            "group": "build"
        },
        {
            "label": "Sign Windows",
            "type": "shell",
            "command": "task",
            "args": ["sign-windows"],
            "group": "build"
        },
        {
            "label": "Build All",
            "type": "shell",
            "command": "task",
            "args": ["default"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                {
                    "owner": "go",
                    "fileLocation": ["relative", "${workspaceFolder}"],
                    "pattern": {
                        "regexp": "^([^:]*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                        "file": 1,
                        "line": 2,
                        "column": 3,
                        "severity": 4,
                        "message": 5
                    }
                }
            ]
        }
    ]
}
  